{
  "name": "local-explorer-for-discord-packages",
  "version": "3.0.0",
  "packageManager": "yarn@3.6.3",
  "engines": {
    "node": ">=20"
  },
  "resolutions": {
    "frappe-charts": "1.5.6",
    "svelte-routing@^2.13.0": "patch:svelte-routing@npm%3A2.13.0#./.yarn/patches/svelte-routing-npm-2.13.0-4e870beae8.patch"
  },
  "scripts": {
    "build": "rollup -c",
