    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "eslint": "^7.20.0",
    "eslint-plugin-svelte3": "^3.1.1",
    "jsdom": "^29.1.1",
    "rollup": "^4.62.2",
    "rollup-plugin-css-only": "^4.5.5",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-svelte": "^7.2.3",
    "svelte": "^5.56.3",
    "svelte-preprocess": "^6.0.5",
